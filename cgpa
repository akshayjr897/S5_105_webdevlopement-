
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart CGPA Planner</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
body{
  margin:0;
  font-family:'Poppins',sans-serif;
  background:linear-gradient(135deg,#0a1128,#001f54);
  color:white;
  text-align:center;
}

header{
  padding:40px;
}

h1{font-size:40px;}
.subtitle{color:#7fdfff;}

.section{padding:30px;}

.card{
  background:rgba(255,255,255,0.05);
  backdrop-filter:blur(12px);
  border-radius:20px;
  padding:25px;
  margin:20px auto;
  max-width:650px;
  box-shadow:0 0 25px rgba(0,240,255,0.2);
}

.card:hover{
  transform:translateY(-5px);
  box-shadow:0 0 35px #00f0ff;
}

input{
  padding:10px;
  margin:5px;
  border-radius:10px;
  border:none;
}

.btn{
  padding:12px 25px;
  margin:10px;
  border:none;
  border-radius:30px;
  background:linear-gradient(45deg,#00f0ff,#00aaff);
  color:black;
  font-weight:bold;
  cursor:pointer;
}

.btn:hover{
  transform:scale(1.1);
  box-shadow:0 0 20px #00f0ff;
}

.result{
  margin-top:20px;
  padding:20px;
  border-radius:15px;
  background:rgba(255,255,255,0.05);
}
</style>
</head>

<body>

<header>
<h1>⚛️ Smart CGPA Planner</h1>
<p class="subtitle">Plan your academic performance smartly</p>
</header>

<div class="section">
<div class="card">

<h2>🎯 Target CGPA Planner</h2>

<input type="number" id="currentCGPA" placeholder="Current CGPA">
<input type="number" id="targetCGPA" placeholder="Target CGPA"><br>

<input type="number" id="subjects" placeholder="Number of Subjects">
<button class="btn" onclick="createSubjects()">Add Subjects</button>

<div id="subjectInputs"></div>

<button class="btn" onclick="calculateSubjects()">Calculate Required Marks</button>

<div id="result" class="result"></div>

</div>
</div>

<script>
function createSubjects(){
  let n = document.getElementById("subjects").value;
  let div = document.getElementById("subjectInputs");
  div.innerHTML = "";

  for(let i=0;i<n;i++){
    div.innerHTML += `
    <div>
      <input id="sub${i}" placeholder="Subject ${i+1}">
      <input id="out${i}" type="number" placeholder="Out of marks">
    </div>`;
  }
}

function calculateSubjects(){
  let n = document.getElementById("subjects").value;
  let current = parseFloat(document.getElementById("currentCGPA").value);
  let target = parseFloat(document.getElementById("targetCGPA").value);

  if(!current || !target){
    document.getElementById("result").innerHTML = "⚠️ Enter CGPA values";
    return;
  }

  // Convert CGPA to %
  let currentPercent = current * 9.5;
  let targetPercent = target * 9.5;

  let improvement = targetPercent - currentPercent;

  if(improvement <= 0){
    document.getElementById("result").innerHTML = "🎉 Target already achieved!";
    return;
  }

  let resultHTML = "<h3>Required Marks per Subject:</h3>";

  for(let i=0;i<n;i++){
    let name = document.getElementById("sub"+i).value || "Subject "+(i+1);
    let out = +document.getElementById("out"+i).value;

    let required = (targetPercent/100) * out;

    resultHTML += `
    <p>📘 <b>${name}</b> → ${required.toFixed(2)} / ${out}</p>
    `;
  }

  resultHTML += `<p style="color:#00f0ff;">📈 You need ~${improvement.toFixed(2)}% improvement overall</p>`;

  document.getElementById("result").innerHTML = resultHTML;
}
</script>

</body>
</html>
